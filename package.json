{
	"name": "svelterm-site",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n parent,iframe -c cyan,magenta \"npm run dev:parent\" \"npm run dev:iframe\"",
		"dev:parent": "vite dev",
		"dev:iframe": "vite --config iframe/vite.config.ts",
		"build": "vite build && vite build --config iframe/vite.config.ts",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@svelterm/core": "file:../svelterm",
		"@types/node": "^25.6.0",
		"concurrently": "^9.1.0",
		"svelte": "file:../svelte-fork/packages/svelte",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@azurity/pure-nerd-font": "^3.0.5",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.41.0",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@replit/codemirror-lang-svelte": "^6.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@svelterm/vt100": "file:../svelterm-vt100",
		"codemirror": "^6.0.2",
		"mdsvex": "^0.12.7",
		"v86": "^0.5.334"
	}
}
