{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "types": ["svelte", "vite/client"],
        "lib": ["ESNext", "DOM", "DOM.Iterable"]
    },
    "include": ["src/**/*"]
}
